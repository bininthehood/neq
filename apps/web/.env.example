# TMDB API — https://www.themoviedb.org/settings/api 에서 발급
TMDB_API_KEY=

# OpenAI API — https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# PostHog Analytics — https://app.posthog.com 에서 프로젝트 생성 후 Project API Key 발급
# NEXT_PUBLIC_ 접두어 필수 (클라이언트에서 접근)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry 에러 모니터링 — https://sentry.io 에서 프로젝트 생성 후 DSN 발급
NEXT_PUBLIC_SENTRY_DSN=

# Supabase — https://supabase.com 에서 프로젝트 생성 후 Settings → API에서 발급
# NEXT_PUBLIC_ 접두어 필수 (클라이언트에서 접근)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Onboarding V2 (P0-2) — taste 단계 선택값을 추천 API 에 전달
# OFF 시 cold_start_version=v1 (모든 사용자). taste_genres 추천 신호 누락.
# Vercel prod env 에도 반드시 등록 필요 (NEXT_PUBLIC_* 빌드 타임 인라인).
NEXT_PUBLIC_TASTE_GENRES_ENABLED=true

# Onboarding OTT — 구독 OTT 를 약한 추천 신호로 사용 (LLM 큐레이션 가중치)
NEXT_PUBLIC_OTT_WEAK_SIGNAL=true

# 알림 (현재 비활성. VAPID 키 발급 + 활성화 결정 시 true)
NEXT_PUBLIC_NOTIFICATIONS_ENABLED=false
