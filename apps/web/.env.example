# TMDB API — https://www.themoviedb.org/settings/api 에서 발급
TMDB_API_KEY=

# OpenAI API — https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# PostHog Analytics — https://app.posthog.com 에서 프로젝트 생성 후 Project API Key 발급
# NEXT_PUBLIC_ 접두어 필수 (클라이언트에서 접근)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry 에러 모니터링 — https://sentry.io 에서 프로젝트 생성 후 DSN 발급
NEXT_PUBLIC_SENTRY_DSN=

# Supabase — https://supabase.com 에서 프로젝트 생성 후 Settings → API에서 발급
# NEXT_PUBLIC_ 접두어 필수 (클라이언트에서 접근)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Onboarding V2 (P0-2) — taste 단계 선택값을 추천 API 에 전달
# OFF 시 cold_start_version=v1 (모든 사용자). taste_genres 추천 신호 누락.
# Vercel prod env 에도 반드시 등록 필요 (NEXT_PUBLIC_* 빌드 타임 인라인).
NEXT_PUBLIC_TASTE_GENRES_ENABLED=true

# Onboarding OTT — 구독 OTT 를 약한 추천 신호로 사용 (LLM 큐레이션 가중치)
NEXT_PUBLIC_OTT_WEAK_SIGNAL=true

# 알림 (현재 비활성. VAPID 키 발급 + 활성화 결정 시 true)
NEXT_PUBLIC_NOTIFICATIONS_ENABLED=false

# === Persona v2 (LLM 동적 취향 설문, 2026-05-24 design) ===
#
# v2 페르소나 생성 UX 활성화. true 시 profile 페이지의 "새 페르소나" CTA 가
# PersonaSurveyController (LLM 동적 설문) 를 mount. false (기본) 시 기존
# NewPersonaSheet (작품 픽만) 사용. PR 2-b 의 backward-safe 분기.
# G2 게이트 통과 + 사용자 본인 점검 후 prod ON 전환 (출시 직전).
NEXT_PUBLIC_PERSONA_SURVEY_V2_ENABLED=false

# Persona-creation-session HMAC token 서명용 비밀키.
# 발급: `openssl rand -hex 32` (특수문자 없는 hex 64자 — 폼/헤더 mangling 방지)
# Vercel prod / preview / dev 각 환경에 다른 값 권장 (사고 격리).
# 미설정 시 /api/onboarding/taste-survey/* 진입 시 서버 500 (≥32자 필수).
TASTE_SURVEY_TOKEN_SECRET=

# === Upstash Redis (Vercel Marketplace 자동 주입) ===
#
# `/api/onboarding/taste-survey/step` 의 IP 당 1h 5 token 발급 rate-limit 저장.
# Vercel Dashboard → Storage → Upstash Redis 통합 시 자동 주입되므로 .env 직접
# 등록 불필요. 로컬 dev 에서 직접 Upstash 호출하려면 Upstash Console 에서
# 값을 복사. 미설정 시 in-memory Map fallback (single-process dev 한정).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
