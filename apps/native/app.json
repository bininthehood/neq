{
  "expo": {
    "name": "neq,",
    "slug": "neko-native",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "neko",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#12110E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.neq.app",
      "buildNumber": "30",
      "associatedDomains": [
        "applinks:neq.me"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "ko",
        "CFBundleLocalizations": [
          "ko"
        ]
      }
    },
    "android": {
      "package": "com.neq.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "neq.me",
              "pathPrefix": "/share/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "locales": {
      "ko": "./locales/ko.json"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "825b73f8-107d-48fe-8dde-726fc07b122f"
      }
    },
    "owner": "bininthehood",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/825b73f8-107d-48fe-8dde-726fc07b122f"
    }
  }
}
