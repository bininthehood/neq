EXPO_PUBLIC_SUPABASE_URL=https://djrmoxzsiyecfhdidllq.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# PostHog product analytics (web과 동일 프로젝트 키)
# 비워두면 native analytics는 no-op (개발 환경 기본)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Onboarding V2 (P0-2) — taste 단계 선택값을 추천 API 에 전달.
# web `NEXT_PUBLIC_TASTE_GENRES_ENABLED` 와 정합. OFF 시 cold_start_version=v1.
EXPO_PUBLIC_TASTE_GENRES_ENABLED=true

# Onboarding OTT — 구독 OTT를 약한 추천 신호로 사용 (LLM 큐레이션 가중치).
EXPO_PUBLIC_OTT_WEAK_SIGNAL=true
