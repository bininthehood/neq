{
  "name": "neq",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "web:dev": "turbo dev --filter=@neq/web",
    "native:ios": "npm run ios -w apps/native",
    "native:start": "npm run start -w apps/native"
  },
  "devDependencies": {
    "turbo": "^2.5.5",
    "typescript": "^5",
    "webdriverio": "^9.27.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
