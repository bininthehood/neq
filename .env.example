# TMDB API — https://www.themoviedb.org/settings/api 에서 발급
TMDB_API_KEY=

# OpenAI API — https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# PostHog Analytics — https://app.posthog.com 에서 프로젝트 생성 후 Project API Key 발급
# NEXT_PUBLIC_ 접두어 필수 (클라이언트에서 접근)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
